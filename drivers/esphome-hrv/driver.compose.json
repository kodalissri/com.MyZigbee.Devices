{
  "name": { "en": "ESPHome HRV" },
  "class": "fan",
  "capabilities": [
    "button.boost_20",
    "button.boost_40",
    "button.boost_60",
    "button.boost_stop",
    "hrv_boost_active",
    "measure_signal_strength",
    "connection_status"
  ],
  "capabilitiesOptions": {
    "alarm_generic": { "title": { "en": "Boost Active" } },
    "button.boost_20": { "title": { "en": "20 Min Boost" } },
    "button.boost_40": { "title": { "en": "40 Min Boost" } },
    "button.boost_60": { "title": { "en": "60 Min Boost" } },
    "button.boost_stop": { "title": { "en": "Stop Boost" } }
  },
  "virtual": true,
  "icon": "{{driverAssetsPath}}/icon.svg",
  "images": {
    "large": "{{driverAssetsPath}}/images/large.png",
    "small": "{{driverAssetsPath}}/images/small.png"
  },
  "settings": [
    { "id": "ip", "type": "text", "label": { "en": "IP Address" }, "value": "" },
    { "id": "port", "type": "number", "label": { "en": "Port" }, "value": 6053 },
    { "id": "encryptionKey", "type": "text", "label": { "en": "Encryption Key (base64)" }, "value": "" }
  ],
  "pair": [
    {
      "id": "start"
    },
    {
      "id": "list_devices",
      "template": "list_devices",
      "navigation": { "next": "add_devices" }
    },
    {
      "id": "add_devices",
      "template": "add_devices"
    }
  ]
}
