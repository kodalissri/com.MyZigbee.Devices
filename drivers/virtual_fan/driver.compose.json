{
  "name": {
    "en": "OmniBreeze Fan"
  },
  "class": "fan",
  "capabilities": [
    "onoff",
    "dim",
    "fan_mode",
    "oscillating",
    "measure_temperature"
  ],
  "capabilitiesOptions": {
    "dim": {
      "title": { "en": "Fan Speed" },
      "min": 0,
      "max": 1,
      "step": 0.25
    },
    "measure_temperature": {
      "title": { "en": "Temperature" }
    }
  },
  "virtual": true,
  "icon": "{{driverAssetsPath}}/icon.svg",
  "images": {
    "large": "{{driverAssetsPath}}/images/large.png",
    "small": "{{driverAssetsPath}}/images/small.png"
  },
  "settings": [
    {
      "id": "mqtt_broker",
      "type": "text",
      "label": { "en": "MQTT Broker Host" },
      "hint": { "en": "IP address or hostname of your MQTT broker (e.g. 192.168.1.100)" },
      "value": ""
    },
    {
      "id": "mqtt_port",
      "type": "number",
      "label": { "en": "MQTT Broker Port" },
      "hint": { "en": "Default is 1883" },
      "value": 1883,
      "min": 1,
      "max": 65535
    },
    {
      "id": "mqtt_username",
      "type": "text",
      "label": { "en": "MQTT Username (optional)" },
      "value": ""
    },
    {
      "id": "mqtt_password",
      "type": "password",
      "label": { "en": "MQTT Password (optional)" },
      "value": ""
    },
    {
      "id": "mqtt_topic",
      "type": "text",
      "label": { "en": "MQTT Topic Prefix" },
      "hint": { "en": "e.g. omnibreeze-fan-1" },
      "value": "omnibreeze-fan-1"
    },
    {
      "id": "beep",
      "type": "checkbox",
      "label": { "en": "Beep" },
      "hint": { "en": "Enable or disable beep sound on button press" },
      "value": true
    },
    {
      "id": "display_leds",
      "type": "checkbox",
      "label": { "en": "Display LEDs" },
      "hint": { "en": "Enable or disable the display panel LEDs" },
      "value": true
    }
  ],
  "pair": [
    {
      "id": "list_devices",
      "template": "list_devices",
      "navigation": {
        "next": "add_devices"
      }
    },
    {
      "id": "add_devices",
      "template": "add_devices"
    }
  ]
}
